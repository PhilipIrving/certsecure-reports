<!-- ═══════════════════ SCRIPT ═══════════════════ -->
<script>
// ──────────────────────────────────────────────
// CLIENT CONFIGURATION
// ──────────────────────────────────────────────
// 'key' must match the value in the 'client' column of your CSVs.
// Update keys here if they differ from your actual CSV values.

const CLIENTS = [
  { name: "A G Equipment",                      key: "agequipment",        structure: "general"  },
  { name: "Canadian Pacific Kansas City",        key: "cpkansascity",       structure: "general"  },
  { name: "Capital Railroad Contracting, Inc.",  key: "capitalrailroad",    structure: "general"  },
  { name: "Kolb Grading",                        key: "kolbgrading",        structure: "general"  },
  { name: "Mizuho Bank",                         key: "mizuhobank",         structure: "general"  },
  { name: "Musselman & Hall Contractors, LLC",   key: "musselmanhall",      structure: "general"  },
  { name: "Paragon Geophysical Services, Inc.",  key: "paragongeophysical", structure: "general"  },
  { name: "Trinity Chemical Industries LLC",     key: "trinitychemical",    structure: "general"  },
  { name: "United Coal Company LLC",             key: "unitedcoal",         structure: "general"  },
  { name: "BAUER Foundation Corp.",              key: "bauer",              structure: "project"  },
  { name: "ESS Companies",                       key: "esscompanies",       structure: "project"  },
  { name: "Scandroli Construction",              key: "scandroli",          structure: "project"  },
  { name: "Skyline Developers Construction LLC", key: "skylinedevelopers",  structure: "project"  },
  { name: "EMMES",                               key: "emmes",              structure: "location" },
  { name: "Gart Properties",                     key: "gartproperties",     structure: "location" },
  { name: "The Abbey Management Company",        key: "theabbeycompany",    structure: "location" },
];

const STRUCT = {
  general:  { label: "General",        groupCol: "entity_type",   groupLabel: "Entity Type", badgeClass: "badge-general"  },
  project:  { label: "Subcontractors", groupCol: "project_name",  groupLabel: "Project",     badgeClass: "badge-project"  },
  location: { label: "Tenants",        groupCol: "location_name", groupLabel: "Location",    badgeClass: "badge-location" },
};

// ──────────────────────────────────────────────
// CSV COLUMN MAPPINGS
// These must match the actual column headers in your CSV files.
// Update here if your CSVs use different names.
// ──────────────────────────────────────────────
const C = {
  // insureds.csv
  client:        'client',
  entity_name:   'display_name',
  contract_num:  'contract_number',
  entity_type:   'party_type',
  project_name:  'project_name',
  location_name: 'location_name',
  status:        'compliance_status',
  verify_status: 'verification_status',
  next_exp:      'next_expiration',
  email:         'contact_email',
  has_coi:       'has_coi',
  // requirements.csv
  coverage_type: 'coverage_type',
  nc_reason:     'non_compliance_reason',
  exp_date:      'expiration_date',
  days_until:    'days_until_expiration',
  // notifications.csv
  notif_email:   'email_address',
  notif_client:  'client',
  issue_type:    'issue_type',
  sent_at:       'sent_at',
  subject:       'subject',
  opened:        'opened',
  clicked:       'clicked',
};

// ──────────────────────────────────────────────
// SETTINGS (stored in localStorage)
// ──────────────────────────────────────────────
const DEFAULTS = {
  owner: 'PhilipIrving',
  repo:  'evident-powerbi',
  branch:'main',
  pat:   '',
  insuredsPath:     'data/insureds.csv',
  requirementsPath: 'data/requirements.csv',
  notificationsPath:'data/notifications.csv',
};

function getSettings() {
  return { ...DEFAULTS, ...JSON.parse(localStorage.getItem('cs-settings') || '{}') };
}

function openSettings() {
  const s = getSettings();
  document.getElementById('s-owner').value       = s.owner;
  document.getElementById('s-repo').value        = s.repo;
  document.getElementById('s-branch').value      = s.branch;
  document.getElementById('s-pat').value         = s.pat;
  document.getElementById('s-insureds').value    = s.insuredsPath;
  document.getElementById('s-requirements').value= s.requirementsPath;
  document.getElementById('s-notifications').value = s.notificationsPath;
  document.getElementById('settings-overlay').classList.add('open');
}

function closeSettings() {
  document.getElementById('settings-overlay').classList.remove('open');
}

function saveSettings() {
  localStorage.setItem('cs-settings', JSON.stringify({
    owner:            document.getElementById('s-owner').value.trim(),
    repo:             document.getElementById('s-repo').value.trim(),
    branch:           document.getElementById('s-branch').value.trim() || 'main',
    pat:              document.getElementById('s-pat').value.trim(),
    insuredsPath:     document.getElementById('s-insureds').value.trim(),
    requirementsPath: document.getElementById('s-requirements').value.trim(),
    notificationsPath:document.getElementById('s-notifications').value.trim(),
  }));
  closeSettings();
  toast('Settings saved', 'success');
}

// ──────────────────────────────────────────────
// DATA LOADING
// ──────────────────────────────────────────────
async function fetchCSV(path) {
  const { owner, repo, branch } = getSettings();
  const url = `https://raw.githubusercontent.com/${owner}/${repo}/${branch}/${path}`;
  const res = await fetch(url);
  if (!res.ok) throw new Error(`Could not load ${path} (HTTP ${res.status}). Check Settings → repo path.`);
  return Papa.parse(await res.text(), { header: true, skipEmptyLines: true }).data;
}

async function triggerRefresh() {
  const { owner, repo, pat } = getSettings();
  if (!pat) { toast('Add a GitHub PAT in Settings to use Refresh Data', 'error'); return; }
  const btn = document.getElementById('refresh-btn');
  btn.textContent = '⟳ Syncing…';
  btn.disabled = true;
  try {
    const res = await fetch(`https://api.github.com/repos/${owner}/${repo}/actions/workflows/sync.yml/dispatches`, {
      method: 'POST',
      headers: { 'Authorization': `Bearer ${pat}`, 'Content-Type': 'application/json', 'Accept': 'application/vnd.github.v3+json' },
      body: JSON.stringify({ ref: 'main' })
    });
    (res.ok || res.status === 204)
      ? toast('Sync triggered — data will refresh in ~2 min', 'success')
      : toast('Sync failed. Check your PAT in Settings.', 'error');
  } catch(e) {
    toast('Network error — could not trigger sync', 'error');
  } finally {
    btn.textContent = '↻ Refresh Data';
    btn.disabled = false;
  }
}

// ──────────────────────────────────────────────
// UI
// ──────────────────────────────────────────────
let selectedClient = null;

function renderGrids() {
  ['general','project','location'].forEach(struct => {
    const grid = document.getElementById(`grid-${struct}`);
    grid.innerHTML = CLIENTS.filter(c => c.structure === struct).map(c => `
      <div class="client-card" id="cc-${c.key}" onclick="pickClient('${c.key}')">
        <div class="client-name">${c.name}</div>
        <span class="client-badge ${STRUCT[struct].badgeClass}">${STRUCT[struct].label}</span>
      </div>
    `).join('');
  });
}

function pickClient(key) {
  selectedClient = CLIENTS.find(c => c.key === key);
  document.querySelectorAll('.client-card').forEach(el => el.classList.remove('selected'));
  document.getElementById(`cc-${key}`)?.classList.add('selected');
  setTimeout(() => goTo(2), 180);
}

function goTo(n) {
  [1,2,3].forEach(i => document.getElementById(`step-${i}`).style.display = 'none');
  document.getElementById(`step-${n}`).style.display = '';
  if (n === 2 && selectedClient) {
    const s = STRUCT[selectedClient.structure];
    document.getElementById('banner-name').textContent   = selectedClient.name;
    document.getElementById('banner-struct').textContent = `${s.label} — Shown by ${s.groupLabel}`;
    document.getElementById('cd-entity-lbl').textContent = s.groupLabel + ' List';
    if (!document.getElementById('g-date').value) {
      document.getElementById('g-date').value = new Date().toISOString().split('T')[0];
    }
    updateGenBtn();
  }
}

function toggleReport(id) {
  document.getElementById(`rc-${id}`).classList.toggle('on');
  updateGenBtn();
}

function updateGenBtn() {
  const any = ['cs','cd','es','ed'].some(id => document.getElementById(`rc-${id}`)?.classList.contains('on'));
  document.getElementById('gen-btn').disabled = !any;
}

function setProgress(lbl, sub) {
  document.getElementById('prog-lbl').textContent = lbl;
  document.getElementById('prog-sub').textContent = sub;
}

// ──────────────────────────────────────────────
// GENERATE
// ──────────────────────────────────────────────
async function generate() {
  const s = getSettings();
  goTo(3);
  document.getElementById('gen-area').style.display  = 'block';
  document.getElementById('done-area').style.display = 'none';
  document.getElementById('err-area').style.display  = 'none';
  document.getElementById('s3-title').textContent    = 'Generating Reports…';
  document.getElementById('s3-sub').textContent      = 'Please wait while your reports are built';

  const on = id => document.getElementById(`rc-${id}`)?.classList.contains('on');
  const E = { cs: on('cs'), cd: on('cd'), es: on('es'), ed: on('ed') };

  try {
    let insureds = [], requirements = [], notifications = [];

    if (E.cs || E.cd || E.ed) {
      setProgress('Fetching compliance data…', `Loading ${s.insuredsPath}`);
      insureds = (await fetchCSV(s.insuredsPath)).filter(r => r[C.client] === selectedClient.key);
    }

    if (E.cd) {
      setProgress('Fetching coverage data…', `Loading ${s.requirementsPath}`);
      try {
        requirements = (await fetchCSV(s.requirementsPath)).filter(r => r[C.client] === selectedClient.key);
      } catch(e) { console.warn('requirements CSV skip:', e.message); }
    }

    if (E.es || E.ed) {
      setProgress('Fetching engagement data…', `Loading ${s.notificationsPath}`);
      try {
        notifications = (await fetchCSV(s.notificationsPath)).filter(r => r[C.notif_client] === selectedClient.key);
      } catch(e) { console.warn('notifications CSV skip:', e.message); }
    }

    const reportDate   = document.getElementById('g-date').value || today();
    const statusFilter = document.getElementById('cd-status').value;
    const engWindow    = parseInt(document.getElementById('ed-window').value) || 60;
    const downloads    = [];

    if (E.cd) {
      setProgress('Building Compliance Detail…', 'Generating Excel workbook');
      const wb   = buildComplianceDetailXL(insureds, requirements, { statusFilter, reportDate });
      downloads.push({ label:'Compliance Detail', type:'excel', blob: xlBlob(wb), filename:`${selectedClient.name} — Compliance Detail.xlsx` });
    }

    if (E.ed) {
      setProgress('Building Engagement Detail…', 'Generating Excel workbook');
      const wb   = buildEngagementDetailXL(insureds, notifications, { engWindow, reportDate });
      downloads.push({ label:'Engagement Detail', type:'excel', blob: xlBlob(wb), filename:`${selectedClient.name} — Engagement Detail.xlsx` });
    }

    if (E.cs) {
      setProgress('Building Compliance Summary…', 'Generating PDF');
      downloads.push({ label:'Compliance Summary', type:'pdf', html: buildComplianceSummaryHTML(insureds, { reportDate }), filename:`${selectedClient.name} — Compliance Summary.pdf` });
    }

    if (E.es) {
      setProgress('Building Engagement Summary…', 'Generating PDF');
      downloads.push({ label:'Engagement Summary', type:'pdf', html: buildEngagementSummaryHTML(notifications, { reportDate }), filename:`${selectedClient.name} — Engagement Summary.pdf` });
    }

    showDownloads(downloads);

  } catch(e) {
    console.error(e);
    document.getElementById('gen-area').style.display = 'none';
    document.getElementById('err-area').style.display = 'block';
    document.getElementById('err-msg').textContent     = e.message || 'Unexpected error';
    document.getElementById('s3-title').textContent    = 'Generation Failed';
  }
}

function showDownloads(downloads) {
  document.getElementById('gen-area').style.display  = 'none';
  document.getElementById('done-area').style.display = 'block';
  document.getElementById('s3-title').textContent    = 'Reports Ready';
  document.getElementById('s3-sub').textContent      = `${downloads.length} report${downloads.length!==1?'s':''} generated`;
  window._dl = downloads;
  document.getElementById('dl-grid').innerHTML = downloads.map((d,i) => `
    <div class="dl-card">
      <div class="dl-icon">${d.type==='excel'?'📊':'📄'}</div>
      <div class="dl-name">${d.label}</div>
      <button class="btn btn-primary" style="width:100%" onclick="dlFile(${i})">
        ⬇ Download ${d.type==='excel'?'Excel':'PDF'}
      </button>
    </div>
  `).join('');
}

function dlFile(i) {
  const d = window._dl[i];
  if (d.type === 'excel') {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(d.blob);
    a.download = d.filename;
    a.click();
  } else {
    const w = window.open('', '_blank');
    w.document.write(d.html);
    w.document.close();
    w.onload = () => { w.focus(); w.print(); };
  }
}

// ──────────────────────────────────────────────
// EXCEL BUILDERS
// ──────────────────────────────────────────────
function xlBlob(wb) {
  const out = XLSX.write(wb, { bookType:'xlsx', type:'array' });
  return new Blob([out], { type:'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
}

function addSheet(wb, data, name, colWidths) {
  if (!data.length) return;
  const ws = XLSX.utils.json_to_sheet(data);
  if (colWidths) ws['!cols'] = colWidths.map(w => ({ wch: w }));
  XLSX.utils.book_append_sheet(wb, ws, name);
}

function buildComplianceDetailXL(insureds, requirements, { statusFilter, reportDate }) {
  const wb    = XLSX.utils.book_new();
  const sl    = STRUCT[selectedClient.structure];
  const total = insureds.length;
  const comp  = insureds.filter(r => normStatus(r[C.status]) === 'compliant').length;
  const nc    = insureds.filter(r => normStatus(r[C.status]) === 'non_compliant').length;
  const newp  = insureds.filter(r => normStatus(r[C.status]) === 'pending').length;
  const coi   = insureds.filter(r => isTruthy(r[C.has_coi])).length;

  // Summary sheet
  const summaryAOA = [
    [`${selectedClient.name} — Compliance Detail`],
    [selectedClient.name],
    [`API Retrieval Date: ${new Date().toLocaleString('en-US',{month:'long',day:'numeric',year:'numeric',hour:'numeric',minute:'2-digit',timeZoneName:'short'})}`],
    [],
    ['Metric','Count','% of Active'],
    ['Active Third-Parties', total, '100%'],
    ['Compliant',    comp, pct(comp, total)],
    ['Non-Compliant', nc,  pct(nc,   total)],
    ['New / Pending', newp,pct(newp,  total)],
    [],
    ['COI on File',    coi,       pct(coi,       total)],
    ['No COI on File', total-coi, pct(total-coi, total)],
  ];
  const wsSummary = XLSX.utils.aoa_to_sheet(summaryAOA);
  wsSummary['!cols'] = [{wch:35},{wch:10},{wch:13}];
  XLSX.utils.book_append_sheet(wb, wsSummary, 'Summary');

  // Entity list sheet
  if (document.getElementById('cd-entitylist').checked) {
    const gCol = sl.groupCol;
    let rows = statusFilter !== 'all' ? insureds.filter(r => normStatus(r[C.status]) === statusFilter) : insureds;
    addSheet(wb, rows.map(r => ({
      'Entity Name':         r[C.entity_name]   || '',
      'Contract Number':     r[C.contract_num]  || '',
      [sl.groupLabel]:       r[gCol]            || '',
      'Compliance Status':   fmtStatus(r[C.status]),
      'Verification Status': r[C.verify_status] || '',
      'Next Expiration':     r[C.next_exp]      || '',
      'Notification Email':  r[C.email]         || '',
    })), `${sl.groupLabel} List`, [35,18,28,18,22,16,30]);
  }

  // Expiring coverage
  if (document.getElementById('cd-expiring').checked && requirements.length) {
    const rows = requirements
      .filter(r => r[C.exp_date] && Number(r[C.days_until]) < 90)
      .sort((a,b) => (Number(a[C.days_until])||999) - (Number(b[C.days_until])||999));
    addSheet(wb, rows.map(r => ({
      'Entity Name':    r[C.entity_name]  || '',
      'Contract Number':r[C.contract_num] || '',
      'Coverage Type':  r[C.coverage_type]|| '',
      'Expiration Date':r[C.exp_date]     || '',
      'Days Until':     r[C.days_until]   || '',
      'Status':         fmtStatus(r[C.status]),
    })), 'Expiring Coverage', [35,18,30,16,12,16]);
  }

  // NC by Coverage
  if (document.getElementById('cd-nccoverage').checked && requirements.length) {
    const map = {};
    requirements.filter(r => normStatus(r[C.status]) === 'non_compliant')
      .forEach(r => { const t = r[C.coverage_type]||'Unknown'; map[t] = (map[t]||0)+1; });
    addSheet(wb, Object.entries(map).sort((a,b)=>b[1]-a[1]).map(([ct,n]) => ({
      'Coverage Type': ct, 'Non-Compliant Entities': n, '% of Active': pct(n, total)
    })), 'NC by Coverage & Criteria', [35,22,14]);
  }

  // NC Reasons
  if (document.getElementById('cd-ncreasons').checked && requirements.length) {
    addSheet(wb, requirements
      .filter(r => normStatus(r[C.status]) === 'non_compliant' && r[C.nc_reason])
      .map(r => ({
        'Entity Name':          r[C.entity_name]   || '',
        'Contract Number':      r[C.contract_num]  || '',
        'Compliance Status':    fmtStatus(r[C.status]),
        'Coverage Type':        r[C.coverage_type] || '',
        'Non-Compliant Reason': r[C.nc_reason]     || '',
      })), 'Non-Compliance Reasons', [35,18,18,30,80]);
  }

  return wb;
}

function buildEngagementDetailXL(insureds, notifications, { engWindow, reportDate }) {
  const wb     = XLSX.utils.book_new();
  const cutoff = new Date(); cutoff.setDate(cutoff.getDate() - engWindow);
  const uniqEmails  = new Set(notifications.map(n => n[C.notif_email]).filter(Boolean));
  const totalSent   = uniqEmails.size;
  const openedCount = new Set(notifications.filter(n => isTruthy(n[C.opened])).map(n => n[C.notif_email])).size;
  const clickedCount= new Set(notifications.filter(n => isTruthy(n[C.clicked])).map(n => n[C.notif_email])).size;
  const issueCount  = new Set(notifications.filter(n => n[C.issue_type]).map(n => n[C.notif_email])).size;
  const noCOI       = insureds.filter(r => !isTruthy(r[C.has_coi])).length;

  const summaryAOA = [
    [`${selectedClient.name} — Engagement Detail`],
    [selectedClient.name],
    [`API Retrieval Date: ${new Date().toLocaleString('en-US',{month:'long',day:'numeric',year:'numeric',hour:'numeric',minute:'2-digit',timeZoneName:'short'})}`],
    [`Data Range: Last ${engWindow} Days`],
    [],
    ['Metric','Count'],
    ['Emails Sent (Unique)', totalSent],
    ['Opened',  openedCount],
    ['Clicked', clickedCount],
    ['Delivery Issues', issueCount],
    [],
    ['No COI on File', noCOI],
  ];
  const wsSummary = XLSX.utils.aoa_to_sheet(summaryAOA);
  wsSummary['!cols'] = [{wch:30},{wch:10}];
  XLSX.utils.book_append_sheet(wb, wsSummary, 'Summary');

  const eRow = r => ({
    'Entity Name':         r[C.entity_name]   || '',
    'Contract Number':     r[C.contract_num]  || '',
    'Compliance Status':   fmtStatus(r[C.status]),
    'Verification Status': r[C.verify_status] || '',
    'Notification Email':  r[C.email]         || '',
    'Next Expiration':     r[C.next_exp]      || '',
  });
  const eCols = [35,18,18,22,30,16];

  if (document.getElementById('ed-nocoi').checked)
    addSheet(wb, insureds.filter(r => !isTruthy(r[C.has_coi])).map(eRow), 'No COIs on File', eCols);

  if (document.getElementById('ed-noeng').checked) {
    const engaged = new Set(notifications.map(n => n[C.notif_email]).filter(Boolean));
    addSheet(wb, insureds.filter(r => { const em = r[C.email]; return !em || !engaged.has(em); }).map(eRow),
      'No Engagement Since Go-Live', eCols);
  }

  if (document.getElementById('ed-ncnoeng').checked) {
    const recent = new Set(notifications.filter(n => n[C.sent_at] && new Date(n[C.sent_at]) >= cutoff).map(n => n[C.notif_email]).filter(Boolean));
    addSheet(wb, insureds.filter(r => {
      return normStatus(r[C.status]) === 'non_compliant' && (!r[C.email] || !recent.has(r[C.email]));
    }).map(eRow), `NC + No ${engWindow}-Day Engagement`, eCols);
  }

  if (document.getElementById('ed-undel').checked) {
    addSheet(wb, notifications.filter(n => n[C.issue_type]).map(n => ({
      'Email':           n[C.notif_email]  || '',
      'Contract Number': n[C.contract_num] || '',
      'Issue Type':      n[C.issue_type]   || '',
      'Date':            n[C.sent_at]      || '',
      'Subject':         n[C.subject]      || '',
    })), 'Undeliverable Emails', [40,18,16,24,60]);
  }

  return wb;
}

// ──────────────────────────────────────────────
// PDF HTML BUILDERS
// Both PDFs open in a new tab → browser Print dialog
// ──────────────────────────────────────────────
const PDF_STYLES = `
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');
  *{box-sizing:border-box;margin:0;padding:0}
