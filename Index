function buildComplianceSummaryHTML(insureds, { reportDate }) {
  const total = insureds.length;
  const comp  = cnt(insureds, r => normStatus(r[C.status]) === 'compliant');
  const nc    = cnt(insureds, r => normStatus(r[C.status]) === 'non_compliant');
  const newp  = cnt(insureds, r => normStatus(r[C.status]) === 'pending');
  const coi   = cnt(insureds, r => isTruthy(r[C.has_coi]));
  const noCOI = total - coi;
  const noCOI_NC   = cnt(insureds, r => !isTruthy(r[C.has_coi]) && normStatus(r[C.status]) === 'non_compliant');
  const noCOI_New  = cnt(insureds, r => !isTruthy(r[C.has_coi]) && normStatus(r[C.status]) === 'pending');
  const noCOI_Comp = noCOI - noCOI_NC - noCOI_New;
  const exp7  = cnt(insureds, r => expiringSoon(r[C.next_exp], 7));
  const exp30 = cnt(insureds, r => expiringSoon(r[C.next_exp], 30));
  const exp60 = cnt(insureds, r => expiringSoon(r[C.next_exp], 60));
  const exp90 = cnt(insureds, r => expiringSoon(r[C.next_exp], 90));
  const fd    = fmtDate(reportDate);

  const showKPI      = chk('cs-kpi');
  const showBreakdown= chk('cs-breakdown');
  const showCOI      = chk('cs-coi');
  const showNoCOI    = chk('cs-nocoi');
  const showExpiring = chk('cs-expiring');

  return `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>${esc(selectedClient.name)} — Compliance Summary</title><style>${PDF_STYLES}</style></head><body><div class="page">
  <div class="hdr">
    <div>${logoHTML()}</div>
    <div class="hdr-right"><div class="badge">Compliance Summary</div><div class="client-name">${esc(selectedClient.name)}</div><div class="rpt-date">Report Date: ${fd}</div></div>
  </div>
  ${showKPI ? `
  <div class="sec-hdr"><div class="sec-title">Program Compliance Summary</div></div>
  <div class="kpi-grid">
    <div class="kpi"><div class="kpi-lbl">Active Third-Parties</div><div class="kpi-val">${total.toLocaleString()}</div><div class="kpi-sub" style="color:#3872B8">Total program scope</div></div>
    <div class="kpi"><div class="kpi-lbl">Compliant</div><div class="kpi-val" style="color:#16A34A">${comp.toLocaleString()}</div><div class="kpi-sub" style="color:#16A34A">${pct(comp,total)} of active</div></div>
    <div class="kpi"><div class="kpi-lbl">Non-Compliant</div><div class="kpi-val" style="color:#DC2626">${nc.toLocaleString()}</div><div class="kpi-sub" style="color:#DC2626">${pct(nc,total)} of active</div></div>
    <div class="kpi"><div class="kpi-lbl">New</div><div class="kpi-val" style="color:#EA580C">${newp.toLocaleString()}</div><div class="kpi-sub" style="color:#EA580C">${pct(newp,total)} of active</div></div>
  </div>` : ''}
  ${(showBreakdown||showCOI) ? `
  <div class="sec-hdr"><div class="sec-title">Compliance Breakdown</div></div>
  <div class="two-col">
    ${showBreakdown ? `<div class="bcard"><div class="bcard-title">Compliance Status</div>
      <div class="brow"><div class="blbl"><span class="dot" style="background:#16A34A"></span>Compliant</div><div class="bval">${comp.toLocaleString()} (${pct(comp,total)})</div></div>
      <div class="brow"><div class="blbl"><span class="dot" style="background:#DC2626"></span>Non-Compliant</div><div class="bval">${nc.toLocaleString()} (${pct(nc,total)})</div></div>
      <div class="brow"><div class="blbl"><span class="dot" style="background:#EA580C"></span>New</div><div class="bval">${newp.toLocaleString()} (${pct(newp,total)})</div></div>
    </div>` : '<div></div>'}
    ${showCOI ? `<div class="bcard"><div class="bcard-title">COI Submission Status</div>
      <div class="brow"><div class="blbl"><span class="dot" style="background:#3872B8"></span>COI on File</div><div class="bval">${coi.toLocaleString()} (${pct(coi,total)})</div></div>
      <div class="brow"><div class="blbl"><span class="dot" style="background:#DC2626"></span>No COI on File</div><div class="bval">${noCOI.toLocaleString()} (${pct(noCOI,total)})</div></div>
    </div>` : '<div></div>'}
  </div>` : ''}
  ${(showNoCOI||showExpiring) ? `
  <div class="sec-hdr"><div class="sec-title">Additional Program Data</div></div>
  <div class="two-col">
    ${showNoCOI ? `<div class="bcard"><div class="bcard-title">No COI on File — Breakdown</div>
      <div class="brow"><div class="blbl">Non-Compliant</div><div class="bval">${noCOI_NC.toLocaleString()} / ${noCOI.toLocaleString()}</div></div>
      <div class="bar"><div class="bar-fill" style="width:${barPct(noCOI_NC,noCOI)}%;background:#DC2626"></div></div>
      <div class="brow" style="margin-top:6px"><div class="blbl">Pending / New</div><div class="bval">${noCOI_New.toLocaleString()} / ${noCOI.toLocaleString()}</div></div>
      <div class="bar"><div class="bar-fill" style="width:${barPct(noCOI_New,noCOI)}%;background:#EA580C"></div></div>
      <div class="brow" style="margin-top:6px"><div class="blbl">Compliant (no COI record)</div><div class="bval">${noCOI_Comp.toLocaleString()} / ${noCOI.toLocaleString()}</div></div>
      <div class="bar"><div class="bar-fill" style="width:${barPct(noCOI_Comp,noCOI)}%;background:#16A34A"></div></div>
    </div>` : '<div></div>'}
    ${showExpiring ? `<div class="bcard"><div class="bcard-title">Expiring Coverage</div>
      <div class="exp-grid">
        <div class="exp-card"><div class="exp-days">7 Days</div><div class="exp-val">${exp7}</div><div class="exp-lbl">entities</div></div>
        <div class="exp-card"><div class="exp-days">30 Days</div><div class="exp-val" style="color:#EA580C">${exp30}</div><div class="exp-lbl">entities</div></div>
        <div class="exp-card"><div class="exp-days">60 Days</div><div class="exp-val">${exp60}</div><div class="exp-lbl">entities</div></div>
        <div class="exp-card"><div class="exp-days">90 Days</div><div class="exp-val">${exp90}</div><div class="exp-lbl">entities</div></div>
      </div>
      <table class="stbl">
        <tr><td>Total Compliant Entities</td><td>${comp}</td></tr>
        <tr><td>Expiring within 30 days</td><td>${exp30} (${pct(exp30,comp)})</td></tr>
        <tr><td>Expiring within 60 days</td><td>${exp60} (${pct(exp60,comp)})</td></tr>
        <tr><td>Expiring within 90 days</td><td>${exp90} (${pct(exp90,comp)})</td></tr>
      </table>
    </div>` : '<div></div>'}
  </div>` : ''}
  <div class="footer">
    <span>🔒 Confidential — HUB CertSecure. Prepared exclusively for ${esc(selectedClient.name)} and HUB International personnel.</span>
    <span>HUB CertSecure — Serviced by HUB International | ${esc(selectedClient.name)} | Compliance Summary | ${fd}</span>
  </div>
</div></body></html>`;
}

function buildEngagementSummaryHTML(notifications, { reportDate }) {
  const fd = fmtDate(reportDate);
  const cutoff60 = new Date(); cutoff60.setDate(cutoff60.getDate() - 60);
  const uniq  = arr => [...new Set(arr.filter(Boolean))];

  const allEmails   = uniq(notifications.map(n => n[C.notif_email]));
  const totalSent   = allEmails.length;
  const opened      = uniq(notifications.filter(n => isTruthy(n[C.opened])).map(n => n[C.notif_email])).length;
  const clicked     = uniq(notifications.filter(n => isTruthy(n[C.clicked])).map(n => n[C.notif_email])).length;
  const issues      = uniq(notifications.filter(n => n[C.issue_type]).map(n => n[C.notif_email])).length;
  const noIssue     = totalSent - issues;
  const notOpened   = totalSent - opened;

  // Issue breakdown
  const iMap = {};
  notifications.filter(n => n[C.issue_type]).forEach(n => {
    const t = n[C.issue_type]; if (!iMap[t]) iMap[t] = new Set(); iMap[t].add(n[C.notif_email]);
  });
  const SEV = { 'Hard Bounce':'crit','hard_bounce':'crit','Rejected':'crit','rejected':'crit' };

  // 60-day
  const n60    = notifications.filter(n => n[C.sent_at] && new Date(n[C.sent_at]) >= cutoff60);
  const sent60 = uniq(n60.map(n => n[C.notif_email])).length;
  const open60 = uniq(n60.filter(n => isTruthy(n[C.opened])).map(n => n[C.notif_email])).length;
  const clk60  = uniq(n60.filter(n => isTruthy(n[C.clicked])).map(n => n[C.notif_email])).length;

  const showKPI     = chk('es-kpi');
  const showOpen    = chk('es-openrate');
  const showDel     = chk('es-delivery');
  const showIssues  = chk('es-issues');
  const show60      = chk('es-60day');

  return `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>${esc(selectedClient.name)} — Engagement Summary</title><style>${PDF_STYLES}</style></head><body><div class="page">
  <div class="hdr">
    <div>${logoHTML()}</div>
    <div class="hdr-right"><div class="badge">Engagement Summary</div><div class="client-name">${esc(selectedClient.name)}</div><div class="rpt-date">Report Date: ${fd}</div></div>
  </div>
  ${showKPI ? `
  <div class="sec-hdr"><div class="sec-title">Email Engagement Summary</div></div>
  <div class="kpi-grid">
    <div class="kpi"><div class="kpi-lbl">Emails Sent</div><div class="kpi-val">${totalSent.toLocaleString()}</div><div class="kpi-sub" style="color:#3872B8">Unique addresses</div></div>
    <div class="kpi"><div class="kpi-lbl">Opened</div><div class="kpi-val" style="color:#16A34A">${opened.toLocaleString()}</div><div class="kpi-sub" style="color:#16A34A">${pct(opened,totalSent)} open rate</div></div>
    <div class="kpi"><div class="kpi-lbl">Clicked</div><div class="kpi-val">${clicked.toLocaleString()}</div><div class="kpi-sub" style="color:#3872B8">${pct(clicked,totalSent)} click rate</div></div>
    <div class="kpi"><div class="kpi-lbl">Delivery Issues</div><div class="kpi-val" style="color:#DC2626">${issues.toLocaleString()}</div><div class="kpi-sub" style="color:#DC2626">${pct(issues,totalSent)} of sent</div></div>
  </div>` : ''}
  ${(showOpen||showDel) ? `
  <div class="sec-hdr"><div class="sec-title">Engagement Breakdown</div></div>
  <div class="two-col">
    ${showOpen ? `<div class="bcard"><div class="bcard-title">Open Rate</div>
      <div class="brow"><div class="blbl"><span class="dot" style="background:#16A34A"></span>Opened</div><div class="bval">${opened.toLocaleString()} (${pct(opened,totalSent)})</div></div>
      <div class="brow"><div class="blbl"><span class="dot" style="background:#E2E8F0"></span>Not Opened</div><div class="bval">${notOpened.toLocaleString()} (${pct(notOpened,totalSent)})</div></div>
    </div>` : '<div></div>'}
    ${showDel ? `<div class="bcard"><div class="bcard-title">Deliverability</div>
      <div class="brow"><div class="blbl"><span class="dot" style="background:#3872B8"></span>No Issues</div><div class="bval">${noIssue.toLocaleString()} (${pct(noIssue,totalSent)})</div></div>
      <div class="brow"><div class="blbl"><span class="dot" style="background:#DC2626"></span>Issues Detected</div><div class="bval">${issues.toLocaleString()} (${pct(issues,totalSent)})</div></div>
    </div>` : '<div></div>'}
  </div>` : ''}
  ${(showIssues||show60) ? `
  <div class="sec-hdr"><div class="sec-title">Additional Engagement Data</div></div>
  <div class="two-col">
    ${showIssues ? `<div class="bcard"><div class="bcard-title">Delivery Issue Breakdown</div>
      <p style="font-size:10px;color:#5A6B7B;margin-bottom:10px">${issues} unique addresses encountered delivery issues.</p>
      <table class="itbl"><thead><tr><th>Issue Type</th><th>Description</th><th>Count</th><th>Severity</th></tr></thead><tbody>
        ${Object.entries(iMap).map(([t,s]) => {
          const isCrit = SEV[t]==='crit';
          const desc = /hard.bounce/i.test(t)?'Address does not exist':/reject/i.test(t)?'Server rejected message':/soft.bounce/i.test(t)?'Temporary failure':'Delivery delayed';
          return `<tr><td style="font-weight:600">${esc(t)}</td><td style="color:#5A6B7B">${desc}</td><td style="font-weight:700">${s.size}</td><td><span class="${isCrit?'crit':'warn'}">${isCrit?'Critical':'Warning'}</span></td></tr>`;
        }).join('')}
      </tbody></table>
    </div>` : '<div></div>'}
    ${show60 ? `<div class="bcard"><div class="bcard-title">60-Day Activity Window</div>
      <p style="font-size:10px;color:#5A6B7B;margin-bottom:12px">Most recent 60-day engagement window.</p>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:14px">
        <div style="text-align:center;border:1px solid #D1DCE8;border-radius:6px;padding:10px"><div style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#5A6B7B">Sent</div><div style="font-size:20px;font-weight:700;color:#3872B8;margin-top:3px">${sent60}</div><div style="font-size:10px;color:#5A6B7B">unique</div></div>
        <div style="text-align:center;border:1px solid #D1DCE8;border-radius:6px;padding:10px"><div style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#5A6B7B">Opened</div><div style="font-size:20px;font-weight:700;color:#16A34A;margin-top:3px">${open60}</div><div style="font-size:10px;color:#5A6B7B">unique</div></div>
        <div style="text-align:center;border:1px solid #D1DCE8;border-radius:6px;padding:10px"><div style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#5A6B7B">Clicked</div><div style="font-size:20px;font-weight:700;color:#1E2E3D;margin-top:3px">${clk60}</div><div style="font-size:10px;color:#5A6B7B">unique</div></div>
      </div>
      <div style="border:1px solid #D1DCE8;border-radius:6px;padding:12px">
        <div style="font-size:9px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:#5A6B7B;margin-bottom:8px">Engagement Funnel</div>
        <div class="frow"><div class="flbl">SENT</div><div class="fbar" style="background:#3872B8"></div><div class="fcount" style="color:#3872B8">${sent60}</div><div class="fpct">100%</div></div>
        <div class="frow"><div class="flbl">OPENED</div><div class="fbar" style="background:#16A34A;width:${barPct(open60,sent60)}%"></div><div class="fcount" style="color:#16A34A">${open60}</div><div class="fpct">${pct(open60,sent60)}</div></div>
        <div class="frow"><div class="flbl">CLICKED</div><div class="fbar" style="background:#1E2E3D;width:${barPct(clk60,sent60)}%"></div><div class="fcount" style="color:#1E2E3D">${clk60}</div><div class="fpct">${pct(clk60,sent60)}</div></div>
      </div>
    </div>` : '<div></div>'}
  </div>` : ''}
  <div class="footer">
    <span>🔒 Confidential — HUB CertSecure. Prepared exclusively for ${esc(selectedClient.name)} and HUB International personnel.</span>
    <span>HUB CertSecure — Serviced by HUB International | ${esc(selectedClient.name)} | Engagement Summary | ${fd}</span>
  </div>
</div></body></html>`;
}

// ──────────────────────────────────────────────
// HELPERS
// ──────────────────────────────────────────────
function normStatus(s) {
  if (!s) return 'unknown';
  const l = s.toLowerCase().replace(/[\s-]/g,'_');
  if (l==='compliant') return 'compliant';
  if (l.includes('non_compliant')||l==='noncompliant') return 'non_compliant';
  if (l==='pending'||l==='new') return 'pending';
  return l;
}
function fmtStatus(s) {
  const n = normStatus(s);
  if (n==='compliant') return 'Compliant';
  if (n==='non_compliant') return 'Non-Compliant';
  if (n==='pending') return 'New';
  return s||'';
}
function isTruthy(v) {
  if (!v) return false;
  return ['true','1','yes'].includes(String(v).toLowerCase().trim());
}
function pct(n, d) { return d ? (Math.round(n/d*1000)/10).toFixed(1)+'%' : '0%'; }
function barPct(n, d) { return d ? Math.min(100, Math.round(n/d*100)) : 0; }
function cnt(arr, fn) { return arr.filter(fn).length; }
function expiringSoon(ds, days) {
  if (!ds) return false;
  const d = new Date(ds); if (isNaN(d)) return false;
  const diff = (d - new Date()) / 86400000;
  return diff >= 0 && diff <= days;
}
function today() { return new Date().toISOString().split('T')[0]; }
function fmtDate(s) {
  if (!s) return new Date().toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
  return new Date(s+'T12:00:00').toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
}
function chk(id) { return document.getElementById(id)?.checked; }
function esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function toast(msg, type='') {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = `toast show ${type}`;
  setTimeout(() => t.className='toast', 3200);
}

// ──────────────────────────────────────────────
// INIT
// ──────────────────────────────────────────────
renderGrids();
</script>
